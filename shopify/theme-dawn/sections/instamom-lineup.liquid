{% comment %}
  InstaMom University — "Current lineup" slider.

  A dynamic section: it loops the chosen collection (default: the Packages
  collection) and renders one card per product, so the lineup updates itself as
  products are added / retagged — no code edits.

  Each card shows:
    - the tag-driven status badge (pre-order / coming-soon / seasonal), reusing
      snippets/instamom-badge.liquid
    - the product title
    - the "cute" blurb, read from the product metafield custom.lineup_blurb,
      falling back to the product description so it works before the metafield
      is created/filled (Settings → Custom data → Products → add a
      "Lineup blurb" definition, key custom.lineup_blurb, type multi-line text).

  The track scrolls horizontally; the prev/next arrows (below) drive it so the
  extra cards past the fold are discoverable.

  Styling: .instamom-lineup* in assets/instamom.css
{% endcomment %}

{%- assign lineup = collections[section.settings.collection] -%}

<div class="instamom-lineup">
  <div class="instamom-lineup__inner page-width">
    <div class="instamom-lineup__header">
      <div class="instamom-lineup__intro">
        {%- if section.settings.kicker != blank -%}
          <p class="instamom-lineup__kicker">{{ section.settings.kicker | escape }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="instamom-lineup__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
      </div>

      {%- if lineup != blank and lineup.products_count > 0 -%}
        <div class="instamom-lineup__controls">
          <button type="button" class="instamom-lineup__arrow" data-lineup-prev aria-label="Previous packages">&larr;</button>
          <button type="button" class="instamom-lineup__arrow" data-lineup-next aria-label="Next packages">&rarr;</button>
        </div>
      {%- endif -%}
    </div>

    {%- if lineup != blank and lineup.products_count > 0 -%}
      <ul class="instamom-lineup__track" data-lineup-track role="list">
        {%- for product in lineup.products limit: section.settings.products_to_show -%}
          {%- assign blurb = product.metafields.custom.lineup_blurb.value | default: product.description -%}
          <li class="instamom-lineup__card">
            {% render 'instamom-badge', product: product %}
            <h3 class="instamom-lineup__title">{{ product.title | escape }}</h3>
            {%- if blurb != blank -%}
              <p class="instamom-lineup__copy">{{ blurb | strip_html | truncatewords: 45 }}</p>
            {%- endif -%}
            <a class="instamom-lineup__link" href="{{ product.url }}">View package &rarr;</a>
          </li>
        {%- endfor -%}
      </ul>
    {%- else -%}
      <p class="instamom-lineup__empty">
        Choose a collection for this section in the theme editor to show your current lineup.
      </p>
    {%- endif -%}
  </div>
</div>

<script>
  (function () {
    var root = document.getElementById('shopify-section-{{ section.id }}');
    if (!root) return;
    var track = root.querySelector('[data-lineup-track]');
    var prev = root.querySelector('[data-lineup-prev]');
    var next = root.querySelector('[data-lineup-next]');
    if (!track) return;

    function step() {
      var card = track.querySelector('.instamom-lineup__card');
      return card ? card.getBoundingClientRect().width + 24 : 374;
    }

    if (prev) prev.addEventListener('click', function () {
      track.scrollBy({ left: -step(), behavior: 'smooth' });
    });
    if (next) next.addEventListener('click', function () {
      track.scrollBy({ left: step(), behavior: 'smooth' });
    });

    // Fade the arrows out at the track's ends so they signal how far you can go.
    function sync() {
      var max = track.scrollWidth - track.clientWidth - 2;
      if (prev) prev.disabled = track.scrollLeft <= 2;
      if (next) next.disabled = track.scrollLeft >= max;
    }
    track.addEventListener('scroll', sync, { passive: true });
    window.addEventListener('resize', sync);
    sync();
  })();
</script>

{% schema %}
{
  "name": "InstaMom Lineup",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Current lineup"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore our customized packages"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 8,
      "label": "Products to show"
    }
  ],
  "presets": [
    {
      "name": "InstaMom Lineup"
    }
  ]
}
{% endschema %}
