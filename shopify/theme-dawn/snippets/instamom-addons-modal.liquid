{% comment %}
  InstaMom University — "add some extras?" modal.

  Opens automatically after a PACKAGE is added to the cart, and on demand from
  the "Add-ons" button on a package's cart line. Rendered once in
  layout/theme.liquid so it is available wherever an add-to-cart can happen.

  The add-on list is rendered server-side from the `add-ons` collection — no
  fetch, so there is no request to fail. Stock is respected: an add-on that is
  unavailable renders as a disabled "Sold out" button rather than being hidden,
  so the lineup always reads the same.

  data-package-ids carries the package product ids so the script can tell a
  package add (open the modal) from an add-on add (don't re-open it).

  Styling: .instamom-addons* in assets/instamom.css
  Behaviour: assets/instamom-addons.js
{% endcomment %}

{%- assign addons = collections['add-ons'].products -%}
{%- if addons.size > 0 -%}
  {%- capture package_ids -%}
    {%- for p in collections['packages'].products -%}{{ p.id }}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}
  {%- endcapture -%}

  <modal-dialog
    id="InstamomAddons"
    class="instamom-addons"
    data-package-ids="{{ package_ids | strip }}"
  >
    <div
      role="dialog"
      aria-modal="true"
      aria-label="Add extras to your box"
      class="instamom-addons__content"
      tabindex="-1"
    >
      <button
        id="ModalClose-InstamomAddons"
        type="button"
        class="instamom-addons__close"
        aria-label="{{ 'accessibility.close' | t }}"
      >
        {{- 'icon-close.svg' | inline_asset_content -}}
      </button>

      <h2 class="instamom-addons__title">Add a little extra?</h2>
      <p class="instamom-addons__intro">
        Customize your student's package with extra treats just for them.
      </p>

      <ul class="instamom-addons__grid" role="list">
        {%- for addon in addons -%}
          {%- assign variant = addon.selected_or_first_available_variant | default: addon.variants.first -%}
          <li class="instamom-addons__item">
            {%- if addon.featured_media -%}
              <img
                class="instamom-addons__image"
                src="{{ addon.featured_media | image_url: width: 300 }}"
                alt="{{ addon.featured_media.alt | escape }}"
                loading="lazy"
                width="150"
                height="150"
              >
            {%- endif -%}
            <span class="instamom-addons__name">{{ addon.title | escape }}</span>
            <span class="instamom-addons__price">{{ addon.price | money }}</span>
            <button
              type="button"
              class="button button--secondary instamom-addons__add"
              data-variant-id="{{ variant.id }}"
              {% unless variant.available %}
                disabled
              {% endunless %}
            >
              {%- if variant.available -%}
                {{ 'products.product.add_to_cart' | t }}
              {%- else -%}
                {{ 'products.product.sold_out' | t }}
              {%- endif -%}
            </button>
          </li>
        {%- endfor -%}
      </ul>

      <div class="instamom-addons__actions">
        <button type="button" class="button instamom-addons__skip">
          No thanks, continue
        </button>
        <a href="{{ routes.cart_url }}" class="instamom-addons__cart-link">View cart</a>
      </div>
    </div>
  </modal-dialog>
{%- endif -%}
