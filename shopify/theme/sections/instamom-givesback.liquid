{% comment %}
  InstaMom University — "Gives Back" band.

  Reproduces the prototype's #gives-back section (../../index.html /
  ../../styles.css): the diploma seal graphic on the LEFT, and the text block on
  the RIGHT (left-aligned) — a "Supporting Our Community" kicker, the title, and
  the scholarship paragraph. Stacks centered on mobile.

  Owner review p.6: "we do need to put a logo" — the logo is the diploma seal
  (imu-diploma-seal.png), NOT the crest or the cap logo.

  The anchor span keeps the header's "Gives Back" → /#gives-back link working.
  Styling: .instamom-givesback* in assets/instamom.css
{% endcomment %}

{%- if section.settings.anchor_id != blank -%}
  <span id="{{ section.settings.anchor_id | handleize }}" class="instamom-anchor"></span>
{%- endif -%}

{%- if section.settings.logo != blank -%}
  {%- assign seal_src = section.settings.logo | image_url: width: 480 -%}
{%- else -%}
  {%- assign seal_src = 'imu-diploma-seal.png' | asset_url -%}
{%- endif -%}

<div class="instamom-givesback color-{{ section.settings.color_scheme }}">
  <div class="instamom-givesback__inner page-width">
    <div class="instamom-givesback__container">
      {%- if seal_src != blank -%}
        <div class="instamom-givesback__seal-side">
          <img
            class="instamom-givesback__seal"
            src="{{ seal_src }}"
            alt="{{ section.settings.logo.alt | default: 'InstaMom University Seal' | escape }}"
            width="240"
            height="240"
            loading="lazy"
          >
        </div>
      {%- endif -%}

      <div class="instamom-givesback__content">
        {%- if section.settings.kicker != blank -%}
          <p class="instamom-givesback__kicker">{{ section.settings.kicker | escape }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="instamom-givesback__title">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <div class="instamom-givesback__text rte">{{ section.settings.text }}</div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "InstaMom Gives Back",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID",
      "info": "Optional. Lets a menu link jump here, e.g. gives-back for a /#gives-back link."
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Seal graphic",
      "info": "Defaults to the IMU diploma seal bundled with the theme."
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Supporting Our Community"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "InstaMom University Gives Back"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "InstaMom Gives Back"
    }
  ]
}
{% endschema %}
