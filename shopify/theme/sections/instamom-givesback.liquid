{% comment %}
  InstaMom University — "Gives Back" band.

  Reproduces the prototype's #gives-back section (../../index.html /
  ../../styles.css): a "Giving Back" kicker, the title flanked left AND right by
  the IMU grad-cap logo (imu-logo-cap.png), and the scholarship paragraph below.
  The flanking logos hide on mobile, matching the prototype.

  Built as its own section (not Dawn's rich-text) because rich-text stacks its
  blocks in a column and can't place a logo beside the heading. Owner review p.6:
  "we do need to put a logo" — the logo is imu-logo-cap.png, not the crest.

  The anchor span keeps the header's "Gives Back" → /#gives-back link working.
  Styling: .instamom-givesback* in assets/instamom.css
{% endcomment %}

{%- if section.settings.anchor_id != blank -%}
  <span id="{{ section.settings.anchor_id | handleize }}" class="instamom-anchor"></span>
{%- endif -%}

{%- if section.settings.logo != blank -%}
  {%- assign logo_src = section.settings.logo | image_url: width: 200 -%}
{%- else -%}
  {%- assign logo_src = 'imu-logo-cap.png' | asset_url -%}
{%- endif -%}

<div class="instamom-givesback color-{{ section.settings.color_scheme }}">
  <div class="instamom-givesback__inner page-width">
    {%- if section.settings.kicker != blank -%}
      <p class="instamom-givesback__kicker">{{ section.settings.kicker | escape }}</p>
    {%- endif -%}

    <div class="instamom-givesback__row">
      {%- if logo_src != blank -%}
        <img class="instamom-givesback__logo" src="{{ logo_src }}" alt="" width="130" height="95" loading="lazy" aria-hidden="true">
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="instamom-givesback__title">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if logo_src != blank -%}
        <img class="instamom-givesback__logo" src="{{ logo_src }}" alt="" width="130" height="95" loading="lazy" aria-hidden="true">
      {%- endif -%}
    </div>

    {%- if section.settings.text != blank -%}
      <div class="instamom-givesback__text rte">{{ section.settings.text }}</div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "InstaMom Gives Back",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID",
      "info": "Optional. Lets a menu link jump here, e.g. gives-back for a /#gives-back link."
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Flanking logo",
      "info": "Defaults to the IMU cap logo bundled with the theme."
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Giving Back"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "InstaMom University Gives Back"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "InstaMom Gives Back"
    }
  ]
}
{% endschema %}
