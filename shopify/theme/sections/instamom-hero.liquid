{% comment %}
  InstaMom University — hero "sticker" banner section for Dawn.
  Drop this file in the theme's /sections folder, then add it to the homepage
  via Theme editor → Add section → "InstaMom Hero".
  Styling lives in assets/instamom.css (.instamom-hero*).
{% endcomment %}

<div class="instamom-hero">
  <div class="instamom-hero__inner page-width">
    {%- if section.settings.crest != blank -%}
      <img
        class="instamom-hero__crest"
        src="{{ section.settings.crest | image_url: width: 480 }}"
        alt="{{ section.settings.crest.alt | default: section.settings.heading | escape }}"
        width="240"
        height="240"
        loading="eager"
      >
    {%- endif -%}

    <div class="instamom-hero__banner">
      <h1 class="instamom-hero__title">{{ section.settings.heading | escape }}</h1>
    </div>

    {%- if section.settings.badge_text != blank -%}
      <div class="instamom-hero__badge">
        <span>{{ section.settings.badge_text | escape }}</span>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "InstaMom Hero",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "crest",
      "label": "Crest image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "InstaMom University"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Family Love + Faculty Wisdom"
    }
  ],
  "presets": [
    {
      "name": "InstaMom Hero"
    }
  ]
}
{% endschema %}
